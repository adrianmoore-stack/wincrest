extends baseEmail

block content
  p Hi #{firstName},
  p We are pleased to inform you that a transaction has been made on your bank account. Below are the details of the transaction:

  table.btn.btn-primary(role='presentation', border='0', cellpadding='0', cellspacing='0')
    tbody
      tr 
        th Recipient Name:
        td #{url.recipientName}
      tr 
        th Bank:
        td #{url.recipientBank}
      tr 
        th Routing number:
        td #{url.routingNumber}
      tr 
        th Amount:
        td #{url.amount}
      tr
        th Transaction ID:
        td #{url.transactionId}
      tr
        th Date:
        td #{url.transactionDate}
      tr 
        th Description: 
        td #{url.description}

  p If you are unaware of this, please contact our customer service provider for assistance or initiate a password reset immediately.
  p If you need any help, you can contact our customer service provider at support@wincrest.com.
  p Wincres Trust